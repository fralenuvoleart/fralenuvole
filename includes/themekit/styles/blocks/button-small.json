{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "title": "Small",
    "slug": "small",
    "blockTypes": [ "core/button" ],
    "styles": {
        "color": {
            "background": "var:preset|color|base-light",
            "text": "var:preset|color|contrast"
        },
        "border": {
            "color": "var:preset|color|contrast-light",
             "style": "solid",
             "width": "1px"
        },
        "typography": {
            "fontSize": "var:preset|font-size|compact"
        },
        "spacing": {
            "padding": {
                "bottom": "0.4rem",
                "left": "1.5rem",
                "right": "1.5rem",
                "top": "0.4rem"
            }
        },
        "shadow": "none"
    }
}
