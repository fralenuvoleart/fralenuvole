<wpml-config>
  <custom-types>
    <custom-type translate="1">service</custom-type>
    <custom-type translate="1">team-member</custom-type>
    <custom-type translate="1">university</custom-type>
    <custom-type translate="1">gd_place</custom-type>
  </custom-types>
  <taxonomies>
    <taxonomy translate="1">post_tag</taxonomy>
    <taxonomy translate="1">service_category</taxonomy>
    <taxonomy translate="0">service_tag</taxonomy>
    <taxonomy translate="1">team_category</taxonomy>
    <taxonomy translate="0">team_tag</taxonomy>
  </taxonomies>
  <custom-fields>

    <custom-field action="copy">post-settings_post-authors</custom-field>
    <custom-field action="copy-once">service-settings_service-type</custom-field>
    <custom-field action="copy-once">service-settings_service-partners</custom-field>
    <custom-field action="copy-once">service-usecases_section-title</custom-field>
