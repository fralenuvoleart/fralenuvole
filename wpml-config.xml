    <key name="website-options_general-settings_address" action="copy-once"/>
    <key name="website-options_general-settings_opening-hours" action="copy-once"/>
    <key name="website-options_general-settings_address-street" action="copy-once"/>
    <key name="website-options_general-settings_address-city" action="copy-once"/>
    <key name="website-options_general-settings_address-zip" action="copy"/>
    <key name="website-options_general-settings_address-country" action="copy-once"/>
