    <key name="website-options_social-media_facebook" action="copy"/>
    <key name="website-options_social-media_facebook_label" action="translate"/>
    <key name="website-options_social-media_instagram" action="copy"/>
    <key name="website-options_social-media_instagram_label" action="translate"/>
    <key name="website-options_social-media_x-twitter" action="copy"/>
