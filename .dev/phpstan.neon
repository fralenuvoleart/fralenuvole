parameters:
    level: 5
    treatPhpDocTypesAsCertain: false
    reportUnmatchedIgnoredErrors: false
    paths:
        - ../ # Scans root + subdirectories recursively
    excludePaths:
        - ../vendor (?)
        - ../node_modules (?)
        - ../tests (?)
        - ../docs (?)
        - ../memory-bank (?)
        - ../assets/fonts (?)
        - ../assets/images (?)
        - ../assets/icons (?)
    bootstrapFiles:
        - stubs/wordpress-stubs.php
        - phpstan-bootstrap.php
        - ../includes/bootstrap.php
        - stubs/polylang.php
        - stubs/wpml.php
        - stubs/acf.php
        - stubs/wsform.php
        - stubs/memberpress.php
    ignoreErrors:
        # Defensive isset checks on arrays - PHPStan incorrectly flags these
        # when it infers types from literal array definitions
        - '#Offset .* on array.*always exists and is not nullable#'
        - '#Offset .* on non-empty-list.* in isset.* always exists#'
        
        # is_array() checks on known array types (defensive coding)
        - '#Call to function is_array\\(\\) with array.* will always evaluate to true#'
        - '#Call to function is_array\\(\\) with array<.*> will always evaluate to true#'
        - '#Call to function is_array\\(\\) with list<.*> will always evaluate to true#'
        - '#Call to function is_array\\(\\) with null.* will always evaluate to false#'
        # is_array() with union types - pattern handles array{}|array{...}
        - '#Call to function is_array\\(\\) with array\{\}.* will always evaluate to true#'
        
        # is_numeric() checks on known int types
        - '#Call to function is_numeric\\(\\) with int.* will always evaluate to true#'
        
        # is_string() checks on known string types (defensive coding)
        - '#Call to function is_string\\(\\) with non-falsy-string will always evaluate to true#'
        - '#Call to function is_string\\(\\) with string will always evaluate to true#'
        - '#Call to function is_string\\(\\) with non-empty-string will always evaluate to true#'
        
        # empty() on variables that always exist (defensive coding)
        - '#Variable .* in empty\\(\\) always exists and is not falsy#'
        - '#Variable .* in empty\\(\\) is never defined#'
        - '#Expression in empty\\(\\) is not falsy#'
        - '#Expression in empty\\(\\) is always falsy#'
        
        # Constant in empty() - defensive check against undefined constants
        - '#Constant .* in empty\\(\\) is never defined#'
        
        # Dead catch blocks - Throwable/Exception never thrown in try block
        - '#Dead catch - Throwable is never thrown in the try block#'
        - '#Dead catch - Exception is never thrown in the try block#'
        
        # function_exists() with known string
        - '#Call to function function_exists\\(\\) with non-falsy-string will always evaluate to true#'
        - '#Call to function function_exists\\(\\) with .* will always evaluate to true#'
        
        # Variable in closure use that may not be defined (defensive)
        - '#Variable .* in empty\\(\\) is never defined#'
        
        # Constant variable in empty() - defensive pattern
        - '#Variable .* in empty\\(\\) always exists and is not falsy#'
        
        # is_array with complex literal types (array{...})
        - '#Call to function is_array\\(\\) with array\\{.*\\} will always evaluate to true#'
        
        # is_array with generic list types
        - '#Call to function is_array\\(\\) with list<.*> will always evaluate to true#'
        
        # Property nullability issues with WordPress types
        - '#Property WP_Post::.*post_content.*on left side of.*is not nullable#'
        - '#Property WP_Post_Type::.*rewrite.*on left side of.*is not nullable#'
        - '#Property WP_Query::.*found_posts.*on left side of.*is not nullable#'
        - '#Property _WP_Dependency::.*src.*on left side of.*is not nullable#'
        - '#Property WP_Post::.*ID.*in isset.* is not nullable#'
        - '#Property WP_Post::.*post_type.*in isset.* is not nullable#'
        - '#Property WP_Taxonomy::.*rewrite.*in isset.* is not nullable#'
        
        # Unused private methods that are kept for extensibility
        - '#Static method Frl_Environment_Manager::.* is unused#'
        
        # Unused parameters in stub files (external library mocks)
        - '#Constructor of class .* has an unused parameter#'
        
        # Unused static properties kept for historical reasons
        - '#Static property Frl_Cache_Manager::.*bypass_cache.*never read.*written#'
        
        # WordPress function stubs returning types that don't match actual return
        - '#Function .* never returns .* so it can be removed from the return type#'
        
        # Comparison operations on known values (defensive coding)
        - '#Strict comparison using === between .* and .* will always evaluate to .*#'
        - '#Strict comparison using !== between .* and .* will always evaluate to .*#'
        - '#Comparison operation .* between .* and .* is always .*#'
        
        # Ternary/if conditions that are always true/false due to constants
        - '#If condition is always true#'
        - '#Ternary operator condition is always true#'
        - '#Result of && is always false#'
        - '#Result of && is always true#'
        - '#Result of \\|\\| is always true#'
        - '#Result of \\|\\| is always false#'
        
        # Unreachable code due to early returns (legitimate)
        - '#Unreachable statement - code above always terminates#'
        
        # Undefined properties/methods in external libraries (memberpress, etc)
        - '#Access to an undefined property MeprTransaction::#'
        - '#Access to an undefined property MeprUser::#'
        - '#Access to an undefined static property MeprTransaction::#'
        - '#Call to an undefined method MeprUser::#'
        
        # Missing function definitions for external plugins
        - '#Function geodir_string_to_options not found#'
        
        # WordPress i18n functions with extra parameters (acceptable)
        - '#Function __ invoked with \d+ parameters, \d+ required#'
        - '#Function _x invoked with \d+ parameters, \d+ required#'
        
        # Function invocations with extra parameters (WordPress patterns)
        - '#Function .* invoked with \d+ parameters, [\d-]+ required#'
        
        # Path existence checks in mu-plugin (runtime-relative paths)
        - '#Path in require_once\\(\\) .* is not a file or it does not exist#'
        
        # Anonymous function unused variables (acceptable)
        - '#Anonymous function has an unused use \\$#'
        
        # PHPDoc parameter references (acceptable)
        - '#PHPDoc tag @param references unknown parameter#'
        
        # Function should return type but returns other
        - '#Function .* should return .* but returns .*#'
        
        # Empty array/foreach issues
        - '#Empty array passed to foreach#'
        
        # Void expression doesn't do anything
        - '#Expression .* on a separate line does not do anything#'
        
        # Constant not found (WordPress constants)
        - '#Constant .* not found#'
        
        # Variable might not be defined (legitimate conditional initialization)
        - '#Variable .* might not be defined#'
        
        # Call on separate line has no effect
        - '#Call to .* on a separate line has no effect#'
        
        # If condition is always false
        - '#If condition is always false#'
        
        # Left side of && is always true
        - '#Left side of && is always true#'
        
        # Right side of && is always false
        - '#Right side of && is always false#'
        
        # Expression on left side of ?? is not nullable
        - '#Expression on left side of \\?\\? is not nullable#'
        
        # Ignore frl_enqueue_scripts WordPress pattern (extra params are intentional)
        - '#Function frl_enqueue_scripts invoked with \d+ parameters#'

        # curl_setopt_array type mismatch - PHPStan doesn't understand int constant values
        - '#curl_setopt_array.*81: false#'
        - '#curl_setopt_array.*CURLOPT_IPRESOLVE#'
        # array_filter with 'strlen' callback - legitimate WordPress/PHP pattern
        - '#array_filter.*strlen#'
        
        # Pre-existing: type narrowing makes is_array() always true after isset checks
        - '#Call to function is_array\(\) with array\{prefix:.*always evaluate to true#'
        - '#Call to function is_array\(\) with array\{\}.*type.*staging.*always evaluate to true#'
