{
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "{{TITLE}}",
  "description": "{{EXCERPT}}",
  "serviceType": "{{BUSINESS_CATEGORY}}",
  "provider": {
    "@type": "Organization",
    "name": "{{BUSINESS_NAME}}",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "{{BUSINESS_ADDRESS}}",
      "addressLocality": "{{BUSINESS_CITY}}",
       "postalCode": "{{BUSINESS_ZIP}}",
       "addressCountry": "{{BUSINESS_COUNTRY}}"
    },
    "telephone": "{{BUSINESS_PHONE}}",
    "image": "{{BUSINESS_IMAGE}}",
    "priceRange": "$$"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "{{CATEGORY}}",
   "itemListElement": [
      {
        "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "{{TITLE}}"
         }
      }
    ]
  }
}