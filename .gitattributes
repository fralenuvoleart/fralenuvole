# Force consistent line endings and treat all files as text
* text=auto eol=lf

# Don't let Git track file mode changes
# This works with core.fileMode=false

# PHP files
*.php text eol=lf diff=php

# CSS/JS files  
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf

# HTML/XML
*.html text eol=lf diff=html
*.xml text eol=lf
*.svg text eol=lf

# Markdown
*.md text eol=lf

# Ensure binary files are never modified
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary

# Dev-only files/directories - excluded from `git archive` / GitHub "Download ZIP"
# (has no effect on deploy.sh, which uses `git reset --hard` on a live clone - see deploy.sh's own prune step for that path)
.dev/ export-ignore
.vscode/ export-ignore
.roo/ export-ignore
.continue/ export-ignore
.roomodes export-ignore
docs/ export-ignore
memory-bank/ export-ignore
plans/ export-ignore
phpcs.xml export-ignore
composer.json export-ignore
composer.lock export-ignore
AGENTS.md export-ignore
.gitattributes export-ignore
.gitignore export-ignore
deploy.sh export-ignore
