			"command": "npx",
			"args": [
				"-y",
				"kinsta-mcp"
			],
			"env": {
				"KINSTA_API_KEY": "a5599e8851f4fd69a1920c488c06bb2d1f0417d0031a7c80b08e515e1f6b0c72",
				"KINSTA_COMPANY_ID": "d4e8f1f8-36a6-418b-bd8c-9735d4659ef3"
			},
			"alwaysAllow": [
				"kinsta.sites.list",
				"kinsta.environments.list",
				"kinsta.environments.ssh.config"
			]
		},
		"context7": {
			"command": "npx",
			"args": [
				"-y",
				"@upstash/context7-mcp"
			],
			"env": {
				"DEFAULT_MINIMUM_TOKENS": ""
