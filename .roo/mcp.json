{
	"mcpServers": {
		"context7": {
			"command": "npx",
			"args": [
				"-y",
				"@upstash/context7-mcp"
			],
			"env": {
				"DEFAULT_MINIMUM_TOKENS": ""
			}
		},
		"filesystem": {
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-filesystem",
				"/mnt/backup/BACKUP/WWW/PBS/public_html/wp-content/plugins/fralenuvole"
			],
			"alwaysAllow": [
				"read_multiple_files",
				"list_directory",
				"edit_file",
				"write_file",
				"search_files",
				"read_file",
				"get_file_info",
				"read_text_file"
			]
		}
	}
}