<?xml version="1.0"?>
<ruleset name="FraleNuvole">
    <description>Coding standard for the Fra Le Nuvole WordPress plugin.</description>

    <!-- Check all PHP files in this plugin by default (used for CLI/full-project scans). -->
    <file>.</file>
    <arg name="extensions" value="php"/>
    <arg value="sp"/>

    <!-- Exclude vendor, build artifacts, generated stubs, and third-party/minified assets. -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/.dev/*</exclude-pattern>
    <exclude-pattern>*/.git/*</exclude-pattern>
    <exclude-pattern>*/assets/*</exclude-pattern>

    <!--
        Use WordPress-Core: matches this codebase's existing conventions
        (tabs for indentation, snake_case function/hook names) without the
        extra opinionated/VIP-style rules from WordPress-Extra or WordPress-Docs
        (Yoda conditions, mandatory docblocks, i18n text-domain literal checks, etc).
    -->
    <rule ref="WordPress-Core">
        <!-- Stylistic-only WPCS opinions that don't affect correctness or match this project's conventions. -->
        <exclude name="WordPress.PHP.YodaConditions"/>
        <exclude name="Universal.Operators.DisallowShortTernary"/>
        <!--
            This project passes text-domain constants (e.g. FRL_NAME) instead of
            hard-coded string literals to i18n functions, which is intentional.
        -->
        <exclude name="WordPress.WP.I18n.NonSingularStringLiteralDomain"/>
        <!-- Not enforcing mandatory "translators:" comments on every placeholder string. -->
        <exclude name="WordPress.WP.I18n.MissingTranslatorsComment"/>
        <!--
            $childNodes is a native PHP DOMNode property (part of the core "dom"
            extension's API, mirroring the browser DOM spec) - it cannot be
            renamed since it's not our code. This only ever fires on that one
            native property access, never on user-defined code.
        -->
        <exclude name="WordPress.NamingConventions.ValidVariableName.UsedPropertyNotSnakeCase"/>
        <!--
            SQL-prepare sniffs produce systemic false positives in this codebase
            and were disabled after a full manual security review (see git history
            for the review notes). Every flagged instance falls into one of two
            confirmed-safe patterns:
              1. "NotPrepared" - the query was already built via $wpdb->prepare()
                 on an earlier line and stored in a variable (often so it can be
                 logged on error), then executed later. The sniff's static
                 analysis cannot trace prepare() calls across statements.
              2. "InterpolatedNotPrepared" for table/column names (e.g.
                 "{$table_log}", "{$wpdb->options}") - identifiers can never use
                 %s/%d placeholders in MySQL; the only real defense is
                 controlling the *source* of the name. Every instance in this
                 codebase builds table names exclusively from $wpdb->prefix
                 (WP-core, admin-controlled) plus a plugin-defined PHP constant
                 (e.g. ACF_MIGRATION_TABLE_LOG) - never from user input, $_GET/
                 $_POST, or a DB-stored value.
            Any NEW SQL code added to this plugin should still be written using
            $wpdb->prepare() with placeholders for all data values, per WordPress
            best practice - this exclusion does not change that requirement, it
            only silences known-safe existing patterns this sniff cannot verify.
        -->
        <exclude name="WordPress.DB.PreparedSQL.NotPrepared"/>
        <exclude name="WordPress.DB.PreparedSQL.InterpolatedNotPrepared"/>
        <exclude name="WordPress.DB.PreparedSQLPlaceholders.UnfinishedPrepare"/>
        <!--
            File-naming conventions (class-{slug}.php, hyphenated-lowercase) are not
            enforced: renaming existing files would risk breaking require/include
            paths and git history for a purely cosmetic gain. Left as a deliberate
            separate refactor if ever desired.
        -->
        <exclude name="WordPress.Files.FileName.InvalidClassFileName"/>
        <exclude name="WordPress.Files.FileName.NotHyphenatedLowercase"/>
    </rule>

    <!--
        These .php files intentionally contain zero PHP code - they are raw
        HTML/JS template snippets (e.g. tracking scripts, embedded iframes)
        included directly for output. PHPCS's "no code found" check is a
        false positive for them.
    -->
    <exclude-pattern>*/config/environment/env-snippets/*_html\.php</exclude-pattern>
    <exclude-pattern>*/admin/metaboxes/metabox-editor\.php</exclude-pattern>
    <exclude-pattern>*/admin/widgets/widget-stats\.php</exclude-pattern>
</ruleset>
