{
    "name": "fralenuvole/fralenuvole-plugin",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "autoload": {
        "psr-4": {
            "Fralenuvole\\FralenuvolePlugin\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Francesco Castronovo",
            "email": "francesco.csto@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "require-dev": {
        "phpstan/phpstan": "^2.1"
    },
    "scripts": {
        "phpstan": "XDEBUG_MODE=off php vendor/bin/phpstan analyse --memory-limit=4G --configuration .dev/phpstan.neon",
        "phpstan:baseline": "XDEBUG_MODE=off php vendor/bin/phpstan analyse --memory-limit=4G --configuration .dev/phpstan.neon --generate-baseline"
    }
}
